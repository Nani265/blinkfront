# Copy to /etc/copilot-api/env on the API server
# chmod 600 /etc/copilot-api/env

# API process
PORT=8081
DATA_PATH=/var/lib/copilot-api/database.sqlite

# WebRTC — required for internet streaming (cross-network / mobile data)
WEBRTC_STUN_URL=stun:stun.l.google.com:19302
WEBRTC_TURN_URL=turn:turn.copilotai.click:3478
WEBRTC_TURN_USERNAME=copilot_turn_user
WEBRTC_TURN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WEBRTC_PHONE_TOKEN_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
WEBRTC_PHONE_TOKEN_TTL_SECONDS=600
WEBRTC_MAX_VIEWERS=10

# After Coturn is installed, set the same user/password in /etc/turnserver.conf
